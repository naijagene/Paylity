{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/platform/layout,_N_T_/platform/page,_N_T_/platform"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/platform/__PAGE__",
    "/platform",
    "/_index",
    "/_head"
  ]
}